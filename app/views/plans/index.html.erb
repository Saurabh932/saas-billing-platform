<div class="container py-5">
  <div class="text-center mb-5">
    <h1 class="display-4 fw-bold">Plans</h1>
    <p class="lead text-muted">Here you can explore the plans and choose which one you want for your work.</p>
  </div>

  <div class="row row-cols-1 row-cols-md-3 g-4 justify-content-center">
    <% @plans.each do |plan| %>
      <div class="col">
        <div class="card h-100 shadow-sm border-light-subtle rounded-3">
          <div class="card-body p-4 d-flex flex-column">
            <h2 class="card-title h4 fw-bold mb-3"><%= plan.name %></h2>
            <h3 class="display-6 fw-bold mb-4">
              $<%= number_with_precision(plan.price_cents / 100.0, precision: 2) %>
              <span class="fs-6 text-muted fw-normal">/mo</span>
            </h3>
            
            <hr class="text-muted opacity-25">

            <ul class="list-unstyled my-4 flex-grow-1">
              <% plan.features.each do |feature| %>
                <li class="mb-3 d-flex align-items-center">
                  <span class="text-success me-2">&#x2713;</span>
                  <%= feature %>
                </li>
              <% end %>
            </ul>

            <%= button_to "Choose #{plan.name}", 
                subscriptions_path, 
                params: { plan_id: plan.id },
                class: "btn btn-primary btn-lg w-full py-2 mt-auto rounded-3 fw-semibold" %>
          </div>
        </div>
      </div>
    <% end %>
  </div>
</div>