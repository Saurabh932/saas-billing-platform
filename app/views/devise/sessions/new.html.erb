<div class="auth-container">
  <div class="auth-card">
    <h2 class="auth-title">Log in</h2>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "auth-form" }) do |f| %>
      <div class="field">
        <%= f.label :email, class: "auth-label" %>
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "auth-input", placeholder: "you@example.com" %>
      </div>

      <div class="field">
        <%= f.label :password, class: "auth-label" %>
        <%= f.password_field :password, autocomplete: "current-password", class: "auth-input", placeholder: "••••••••" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="field-checkbox">
          <%= f.check_box :remember_me, class: "auth-checkbox" %>
          <%= f.label :remember_me, class: "auth-checkbox-label" %>
        </div>
      <% end %>

      <div class="actions">
        <%= f.submit "Log in", class: "auth-submit-btn" %>
      </div>
    <% end %>

    <div class="auth-links">
      <%= render "devise/shared/links" %>
    </div>
  </div>
</div>